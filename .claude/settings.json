{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run lint:*)",
      "Bash(npm run build)",
      "Bash(npm run test:chart)",
      "Bash(npm ci)",
      "Bash(npm ci:*)",
      "Bash(npm install)",
      "Bash(npm install:*)",
      "Bash(npm ls:*)",
      "Bash(npx playwright:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git add:*)",
      "Bash(git restore:*)",
      "Bash(git stash:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git push origin HEAD:claude/*)",
      "Bash(git push origin HEAD:main)",
      "Bash(git push -u origin claude/*)",
      "Bash(git rev-list:*)",
      "Bash(npm run start)",
      "Bash(npm run dev)",
      "Bash(kill:*)",
      "Bash(pkill:*)",
      "Bash(curl:*)",
      "Bash(curl -I:*)",
      "Bash(curl -sI:*)",
      "Bash(curl --max-time:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(jq:*)",
      "mcp__github__pull_request_read",
      "mcp__github__create_pull_request",
      "mcp__github__list_pull_requests",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_navigate_back",
      "mcp__playwright__browser_take_screenshot",
      "mcp__playwright__browser_snapshot",
      "mcp__playwright__browser_wait_for",
      "mcp__playwright__browser_resize",
      "mcp__playwright__browser_network_requests",
      "mcp__playwright__browser_network_request",
      "mcp__playwright__browser_console_messages",
      "mcp__06b53b3b-8e6e-461c-a3cb-0a1e2ed03e49__list_teams",
      "mcp__06b53b3b-8e6e-461c-a3cb-0a1e2ed03e49__list_projects",
      "mcp__06b53b3b-8e6e-461c-a3cb-0a1e2ed03e49__list_deployments",
      "mcp__06b53b3b-8e6e-461c-a3cb-0a1e2ed03e49__get_deployment",
      "Bash(fly status:*)",
      "Bash(fly logs:*)",
      "Bash(fly machine list:*)",
      "Bash(fly machine status:*)",
      "Bash(fly machine start:*)",
      "Bash(fly machine restart:*)",
      "Bash(fly apps list)",
      "Bash(fly version)",
      "Bash(fly auth whoami)",
      "Bash(flyctl status:*)",
      "Bash(flyctl logs:*)",
      "Bash(flyctl version)",
      "Bash(flyctl auth whoami)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-boundary.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}
