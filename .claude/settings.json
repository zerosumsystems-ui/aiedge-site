{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run lint:*)",
      "Bash(npm run build)",
      "Bash(npm run test:chart)",
      "Bash(npm ci)",
      "Bash(npm ci:*)",
      "Bash(npm install)",
      "Bash(npm install:*)",
      "Bash(npm ls:*)",
      "Bash(npx playwright:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git add:*)",
      "Bash(git restore:*)",
      "Bash(git stash:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git push origin HEAD:claude/*)",
      "Bash(curl -I:*)",
      "Bash(curl -sI:*)",
      "Bash(curl --max-time:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(jq:*)",
      "Bash(fly status:*)",
      "Bash(fly logs:*)",
      "Bash(fly machine list:*)",
      "Bash(fly machine status:*)",
      "Bash(fly machine start:*)",
      "Bash(fly machine restart:*)",
      "Bash(fly apps list)",
      "Bash(fly version)",
      "Bash(fly auth whoami)",
      "Bash(flyctl status:*)",
      "Bash(flyctl logs:*)",
      "Bash(flyctl version)",
      "Bash(flyctl auth whoami)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-boundary.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}
