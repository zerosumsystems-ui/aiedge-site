# AIedge — environment variables
#
# Copy to `.env.local` and fill in real values. The same vars must also be
# set in:
#   • Vercel (Production + Preview + Development)
#   • The Claude Code cloud environment (Environment settings UI), so web
#     sessions can run `npm run build`, `npm run test:chart`, and curl the
#     site without extra prompts.
#   • The scanner / aggregator shell environments where applicable, so
#     scripts/live/*.py and live_scanner.py can authenticate.
#
# See AGENTS.md → "Cloud environment" for the full convention.

# ── Supabase (auth + DB) ─────────────────────────────────────────────
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
# Server-only. Never import from client code. Used by src/lib/supabase/admin.ts.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Comma-separated email allowlist. Empty = nobody can sign in.
# Case-insensitive; whitespace is trimmed.
ALLOWED_EMAILS=will@example.com,friend@example.com

# Shared secret for sync scripts that POST to /api/* or GET gated endpoints.
# Generate with: openssl rand -hex 32
# Must match the SYNC_SECRET exported in ~/code/aiedge/scanner/.env (or your
# shell) so live_scanner.py can authenticate.
SYNC_SECRET=replace-with-long-random-hex-string

# ── Databento (market data) ──────────────────────────────────────────
# Historical bars (/api/bars) and live aggregator on Fly.
DATABENTO_API_KEY=db-XXXX

# ── Live bars wiring (Issue #26) ─────────────────────────────────────
# LIVE_DATASET / LIVE_SCHEMA / LIVE_SYMBOLS are read by
# scripts/live/live_bars_aggregator.py on Fly. UPSTASH_* are read by both
# the aggregator (write side) and /api/bars/live in Vercel (read side).
#
# The entitlement probe should be the source of truth. As of the first live
# smoke test, DBEQ.BASIC requires another live license, while EQUS.MINI accepts
# both trades and ohlcv-1m subscriptions. Use the market-hours proof run to
# choose between LIVE_SCHEMA=ohlcv-1m and LIVE_SCHEMA=trades.
LIVE_DATASET=EQUS.MINI
LIVE_SCHEMA=ohlcv-1m
LIVE_SYMBOLS=SPY,QQQ,NVDA,TSLA,META,GOOGL,AAPL,MSFT,AMZN
UPSTASH_REDIS_REST_URL=https://YOUR-DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_TOKEN

# Upstream Fly URL for /api/bars/live/subscribe and diagnostics.
# Defaults to https://aiedge-live-bars.fly.dev when unset.
LIVE_BARS_INTERNAL_URL=https://aiedge-live-bars.fly.dev
# Optional shared bearer between Vercel and the Fly aggregator. Leave empty
# if the Fly app is open / IP-scoped.
LIVE_SUBSCRIBE_TOKEN=

# Optional Python-script knobs (read by scripts/, never by Vercel/Next):
#   EXTRA_ENV_FILE     — extra .env file the aggregator loads after
#                        .env.local/.env. Used for local runs against a
#                        separate credentials file; unset on Fly.
#   VIDEO_PIPELINE_DIR — path to a local scanner checkout, so the sync
#                        scripts (sync_audit.py / sync_trades.py) and the
#                        entitlements probe can import its databento client.
EXTRA_ENV_FILE=
VIDEO_PIPELINE_DIR=

# ── SnapTrade (brokerage connect) ────────────────────────────────────
# Dashboard → API Keys. Used by src/lib/snaptrade/client.ts and
# /api/snaptrade/register.
SNAPTRADE_CLIENT_ID=YOUR_SNAPTRADE_CLIENT_ID
SNAPTRADE_CONSUMER_KEY=YOUR_SNAPTRADE_CONSUMER_KEY
# Where SnapTrade redirects users after the connect flow. Falls back to
# the request origin when unset; set this in Production for a stable URL.
SNAPTRADE_REDIRECT_URI=https://www.aiedge.trade/connect/return

# ── Sentry (error monitoring) ────────────────────────────────────────
# DSNs are public by design (they only allow writing events). They live in
# Vercel + the Claude Code Environment UI, NOT in any secret store.
#
# `instrumentation.ts` and `instrumentation-client.ts` read NEXT_PUBLIC_SENTRY_DSN
# to wire @sentry/nextjs for the Next.js app. Leave blank in local dev to
# silence Sentry entirely.
NEXT_PUBLIC_SENTRY_DSN=https://b98ddcd68835fd6a9e384fbbb8134922@o4511386173898752.ingest.us.sentry.io/4511386261323776

# DSN for the Fly aggregator (Python). Set in Fly secrets, not Vercel.
# Read by scripts/live/live_bars_aggregator.py when sentry-sdk is wired in.
#   fly secrets set SENTRY_DSN=... -a aiedge-live-bars
SENTRY_DSN_AGGREGATOR=https://994d3eeb2e7aa24f58e3302128d6b361@o4511386173898752.ingest.us.sentry.io/4511386261389312

# Optional. Set in CI (and Claude Code Environment) to enable source-map
# upload during `next build` via withSentryConfig. Without it builds still
# succeed, you just won't get readable stack traces in Sentry.
#   Create at https://zerosumsystems.sentry.io/settings/auth-tokens/
SENTRY_AUTH_TOKEN=

# ── Fly.io (live-bars aggregator deploys) ────────────────────────────
# Optional. Only needed in the Claude Code cloud Environment settings
# UI — never in Vercel, never committed. When set, Claude can run
# `fly status`, `fly logs`, and `fly deploy -c fly.live-bars.toml`
# directly from a web session. The same token also lives in GitHub
# Secrets (named FLY_API_TOKEN) for the auto-deploy workflow at
# .github/workflows/deploy-live-bars.yml.
#
# Create with:  fly tokens create deploy -a aiedge-live-bars
FLY_API_TOKEN=
