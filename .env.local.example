# Phase 5 — Supabase magic-link auth + sync-secret gating
#
# Copy to `.env.local` and fill in real values. The same four vars must
# also be set in Vercel (Production + Preview + Development) and in the
# scanner's shell environment so live_scanner.py can POST to /api/scan.

# Supabase project — Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Comma-separated email allowlist. Empty = nobody can sign in.
# Case-insensitive; whitespace is trimmed.
ALLOWED_EMAILS=will@example.com,friend@example.com

# Shared secret for sync scripts that POST to /api/* or GET gated endpoints.
# Generate with: openssl rand -hex 32
# Must match the SYNC_SECRET exported in ~/code/aiedge/scanner/.env (or your
# shell) so live_scanner.py can authenticate.
SYNC_SECRET=replace-with-long-random-hex-string

# Databento — historical bars (/api/bars) and live aggregator
DATABENTO_API_KEY=db-XXXX

# Issue #26 — live bars wiring.
# LIVE_DATASET / LIVE_SYMBOLS are read by scripts/live_bars_aggregator.py on
# the Mac mini. UPSTASH_* are read by both the aggregator (write side) and
# /api/bars/live in Vercel (read side).
LIVE_DATASET=DBEQ.BASIC
LIVE_SYMBOLS=SPY,QQQ,NVDA,TSLA,META,GOOGL,AAPL,MSFT,AMZN
UPSTASH_REDIS_REST_URL=https://YOUR-DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_TOKEN
