# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results
/playwright-report
/.playwright-mcp

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Local model/data artifacts — ignore everything inside artifacts/...
/artifacts/*
# ... except the production joblib model, which is baked into the Fly
# image at deploy time. Only the production target (mfe_ge_1pct) ships;
# net_positive + reports + dataset stay local.
!/artifacts/tfo-baseline/
/artifacts/tfo-baseline/*
!/artifacts/tfo-baseline/tfo_baseline_mfe_ge_1pct.joblib
# ... and the backtest reports — the headline results are versioned so
# they're auditable. Trade ledgers + the 1-min bar cache stay local
# (regenerable, and large).
!/artifacts/backtest/
/artifacts/backtest/*
!/artifacts/backtest/backtest_report.json
!/artifacts/backtest/spike_backtest_report.json
!/artifacts/backtest/prior_day_extremes_report.json

# env files (can opt-in for committing if needed)
.env*
!.env*.example
# python bytecode (from scripts/)
__pycache__/

# vercel
.vercel

# supabase CLI local state (project-ref, pooler url, etc)
/supabase/.temp/

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local
